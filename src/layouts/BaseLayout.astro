---
import '@styles/global.css';
import BaseHead from '@components/seo/BaseHead.astro';
import Header from '@components/layout/Header.astro';
import Footer from '@components/layout/Footer.astro';

interface Props {
  title: string;
  description?: string;
  lang?: 'en' | 'es';
}

const {
  title,
  description = 'Artist and restorer portfolio website.',
  lang = 'en',
} = Astro.props;
---

<!doctype html>
<html lang={lang}>
  <head>
    <BaseHead title={title} description={description} />
  </head>
  <body class="site-shell">
    <Header locale={lang} currentPath={Astro.url.pathname} />
    <slot />
    <Footer locale={lang} />
  </body>
</html>
