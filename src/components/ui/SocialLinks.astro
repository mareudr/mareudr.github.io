---
import type { SocialItem } from '../../data/site';

interface Props {
  items: SocialItem[];
}

const { items } = Astro.props;
---

<ul class="flex flex-wrap gap-3">
  {items.map((item) => (
    <li>
      <a
        href={item.href}
        class="inline-flex rounded-full border border-neutral-200 bg-white px-4 py-2 text-sm font-medium text-neutral-700 transition-all duration-300 ease-in-out hover:-translate-y-0.5 hover:text-brand-500 hover:shadow-card"
        target={item.href.startsWith('http') ? "_blank" : undefined}
        rel={item.href.startsWith('http') ? "noopener noreferrer" : undefined}
      >
        {item.label}
      </a>
    </li>
  ))}
</ul>
