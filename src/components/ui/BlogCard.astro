---
import { Image } from 'astro:assets';

interface Props {
  href: string;
  title: string;
  summary: string;
  image: ImageMetadata;
  alt: string;
  date: Date;
  locale: 'en' | 'es';
}

const { href, title, summary, image, alt, date, locale } = Astro.props;
const dateLocale = locale === 'en' ? 'en-US' : 'es-AR';
---

<article class="surface-card overflow-hidden">
  <a href={href} class="group block">
    <div class="overflow-hidden">
      <Image
        src={image}
        alt={alt}
        class="aspect-[16/10] w-full object-cover transition-all duration-300 ease-in-out group-hover:scale-105"
      />
    </div>
    <div class="space-y-3 p-5">
      <p class="text-xs uppercase tracking-[0.2em] text-neutral-400">
        {date.toLocaleDateString(dateLocale, { year: 'numeric', month: 'long', day: 'numeric' })}
      </p>
      <h3 class="text-2xl text-neutral-900">{title}</h3>
      <p class="text-sm text-neutral-700">{summary}</p>
    </div>
  </a>
</article>
