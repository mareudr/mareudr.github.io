---
import { getCollection } from 'astro:content';
import BaseLayout from '@layouts/BaseLayout.astro';
import ProjectCard from '@components/ui/ProjectCard.astro';
import { siteCopy } from '../../../data/site';

const copy = siteCopy.en;
const lang = 'en';

const allProjects = await getCollection('projects-en');
allProjects.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

// Get unique categories and tags for filters
const categories = [...new Set(allProjects.map((p) => p.data.category))];
const tags = [...new Set(allProjects.flatMap((p) => p.data.tags))].sort();

// Handle filtering via URL params (for static build these will be initial states if we had JS, 
// but since it's static, we might want to use client-side JS for filtering or generate pages.
// The requirements say "category and tag filtering". For a pure static site without JS, 
// we'd need separate pages. But Astro can do client-side too.
// Let's implement a simple client-side filter for now or keep it simple with just the grid.
// If I use URL params, it needs to be an SSR site or use client JS.
// Given "Static site generator" in tech stack, I'll use simple client-side JS for the filtering UI.)
---

<BaseLayout lang={lang} title={`${copy.projectsTitle}`} description={copy.pageDescriptions.projects}>
  <main class="section-block">
    <section class="page-container">
      <header class="mb-12">
        <h1 class="section-title mb-6">{copy.projectsTitle}</h1>
        
        <!-- Filter UI -->
        <div class="flex flex-col md:flex-row gap-6 md:items-center">
          <div class="flex flex-wrap gap-2">
            <button 
              class="filter-btn active px-4 py-2 rounded-md border border-neutral-200 text-sm transition-all hover:border-brand-500"
              data-category="all"
            >
              {copy.allLabel}
            </button>
            {categories.map(cat => (
              <button 
                class="filter-btn px-4 py-2 rounded-md border border-neutral-200 text-sm transition-all hover:border-brand-500"
                data-category={cat}
              >
                {copy.categoryLabels[cat]}
              </button>
            ))}
          </div>
          
          <div class="h-6 w-[1px] bg-neutral-200 hidden md:block"></div>
          
          <div class="flex flex-wrap gap-2">
            <button 
              class="tag-btn active px-3 py-1.5 rounded-full border border-neutral-200 text-xs transition-all hover:border-brand-500"
              data-tag="all"
            >
              {copy.allLabel}
            </button>
            {tags.map(tag => (
              <button 
                class="tag-btn px-3 py-1.5 rounded-full border border-neutral-200 text-xs transition-all hover:border-brand-500"
                data-tag={tag}
              >
                #{tag}
              </button>
            ))}
          </div>
        </div>
      </header>

      <div id="projects-grid" class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        {allProjects.map((project) => (
          <div 
            class="project-item" 
            data-category={project.data.category} 
            data-tags={JSON.stringify(project.data.tags)}
          >
            <ProjectCard
              href={`/en/projects/${project.id}/`}
              title={project.data.title}
              summary={project.data.summary}
              image={project.data.thumbnail}
              alt={project.data.title}
              category={copy.categoryLabels[project.data.category]}
              date={project.data.date}
              locale={lang}
            />
          </div>
        ))}
      </div>

      <div id="empty-state" class="hidden py-20 text-center">
        <p class="text-neutral-500">{copy.projectsEmpty}</p>
      </div>
    </section>
  </main>
</BaseLayout>

<script>
  function setupFilters() {
    const filterBtns = document.querySelectorAll('.filter-btn');
    const tagBtns = document.querySelectorAll('.tag-btn');
    const projectItems = document.querySelectorAll('.project-item') as NodeListOf<HTMLElement>;
    const emptyState = document.getElementById('empty-state');

    let currentCategory = 'all';
    let currentTag = 'all';

    function filter() {
      let visibleCount = 0;
      projectItems.forEach(item => {
        const itemCategory = item.dataset.category;
        const itemTags = JSON.parse(item.dataset.tags || '[]');
        
        const matchesCategory = currentCategory === 'all' || itemCategory === currentCategory;
        const matchesTag = currentTag === 'all' || itemTags.includes(currentTag);

        if (matchesCategory && matchesTag) {
          item.classList.remove('hidden');
          visibleCount++;
        } else {
          item.classList.add('hidden');
        }
      });

      if (visibleCount === 0) {
        emptyState?.classList.remove('hidden');
      } else {
        emptyState?.classList.add('hidden');
      }
    }

    filterBtns.forEach(btn => {
      btn.addEventListener('click', () => {
        filterBtns.forEach(b => b.classList.remove('active', 'bg-brand-500', 'text-white', 'border-brand-500'));
        btn.classList.add('active', 'bg-brand-500', 'text-white', 'border-brand-500');
        currentCategory = (btn as HTMLElement).dataset.category || 'all';
        filter();
      });
    });

    tagBtns.forEach(btn => {
      btn.addEventListener('click', () => {
        tagBtns.forEach(b => b.classList.remove('active', 'bg-neutral-900', 'text-white', 'border-neutral-900'));
        btn.classList.add('active', 'bg-neutral-900', 'text-white', 'border-neutral-900');
        currentTag = (btn as HTMLElement).dataset.tag || 'all';
        filter();
      });
    });

    // Initialize active button styles
    const activeFilterBtn = document.querySelector('.filter-btn.active');
    if (activeFilterBtn) {
      activeFilterBtn.classList.add('bg-brand-500', 'text-white', 'border-brand-500');
    }
    const activeTagBtn = document.querySelector('.tag-btn.active');
    if (activeTagBtn) {
      activeTagBtn.classList.add('bg-neutral-900', 'text-white', 'border-neutral-900');
    }
  }

  // Run on initial load
  setupFilters();
  // Run on view transitions if enabled
  document.addEventListener('astro:after-swap', setupFilters);
</script>

<style>
  .filter-btn.active {
    /* Styles are handled by JS to keep it simple with Tailwind classes */
  }
</style>
