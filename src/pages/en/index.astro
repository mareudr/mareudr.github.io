---
import { getCollection } from 'astro:content';
import BaseLayout from '@layouts/BaseLayout.astro';
import Hero from '@components/ui/Hero.astro';
import ProjectCard from '@components/ui/ProjectCard.astro';
import BlogCard from '@components/ui/BlogCard.astro';
import { siteCopy } from '../../data/site';

const copy = siteCopy.en;
const lang = 'en';

const [projects, posts] = await Promise.all([
  getCollection('projects-en'),
  getCollection('blog-en'),
]);

const featuredProjects = projects
  .filter((entry) => entry.data.featured)
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime())
  .slice(0, 4);

const latestPosts = [...posts]
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime())
  .slice(0, 2);

const heroImages = featuredProjects.map((entry) => ({
  src: entry.data.thumbnail,
  alt: entry.data.images[0]?.alt ?? entry.data.title,
}));
---

<BaseLayout lang={lang} title={`${copy.siteTitle} | ${copy.siteTagline}`} description={copy.pageDescriptions.home}>
  <main>
    <Hero
      heroName={copy.heroName}
      heroImage={copy.heroImage}
      title={copy.heroTitle}
      body={copy.heroBody}
      primaryHref={copy.routes.projects}
      primaryLabel={copy.heroPrimaryCta}
      secondaryHref={copy.routes.about}
      secondaryLabel={copy.heroSecondaryCta}
    />
    <!-- About & Projects Grid -->
    <section class="section-block pt-0">
      <div class="page-container grid gap-16 lg:grid-cols-[0.8fr_1.2fr] lg:items-start">
        <div class="space-y-6 lg:sticky lg:top-24">
          <p class="eyebrow">{copy.aboutEyebrow}</p>
          <h2 class="section-title text-4xl leading-tight">{copy.aboutTitle}</h2>
          <p class="section-copy text-lg font-light">{copy.aboutBody}</p>
          <div class="pt-4">
            <a href={copy.routes.about} class="button-secondary">{copy.aboutLink}</a>
          </div>
        </div>
        
        <div class="grid gap-8 md:grid-cols-2">
          {featuredProjects.map((project) => (
            <ProjectCard
              href={`/en/projects/${project.id}/`}
              title={project.data.title}
              summary={project.data.summary}
              image={project.data.thumbnail}
              alt={project.data.title}
              category={copy.categoryLabels[project.data.category]}
              date={project.data.date}
              locale={lang}
            />
          ))}
        </div>
      </div>
    </section>

    <!-- Latest Posts -->
    <section class="section-block bg-neutral-50/50">
      <div class="page-container">
        <div class="mb-12 flex flex-col gap-4 md:flex-row md:items-end md:justify-between">
          <div class="space-y-3">
            <p class="eyebrow">{copy.blogEyebrow}</p>
            <h2 class="section-title">{copy.blogTitle}</h2>
          </div>
          <a href={copy.routes.blog} class="button-secondary">{copy.blogLink}</a>
        </div>

        {latestPosts.length > 0 ? (
          <div class="grid gap-8 md:grid-cols-2">
            {latestPosts.map((post) => (
              <BlogCard
                href={`/en/blog/${post.id}/`}
                title={post.data.title}
                summary={post.data.summary}
                image={post.data.thumbnail}
                alt={post.data.title}
                date={post.data.date}
                locale={lang}
              />
            ))}
          </div>
        ) : (
          <div class="py-20 text-center border border-dashed border-neutral-200 rounded-lg bg-white">
            <p class="text-neutral-500 font-light">{copy.blogEmpty}</p>
          </div>
        )}
      </div>
    </section>

  </main>
</BaseLayout>
