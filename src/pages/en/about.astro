---
import BaseLayout from '@layouts/BaseLayout.astro';
import { siteCopy } from '../../data/site';

const copy = siteCopy.en;
const lang = 'en';
---

<BaseLayout lang={lang} title={`${copy.nav[1].label}`} description={copy.pageDescriptions.about}>
  <main class="section-block">
    <section class="page-container">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 lg:gap-24 items-start">
        <div class="space-y-8">
          <div>
            <p class="eyebrow mb-4">{copy.aboutEyebrow}</p>
            <h1 class="section-title text-4xl md:text-5xl lg:text-6xl leading-tight">
              {copy.aboutTitle}
            </h1>
          </div>
          
          <div class="space-y-6 text-lg text-neutral-600 font-light leading-relaxed">
            <p>{copy.aboutBody}</p>
            <p>
              The practice is built on a foundation of respect for the original work, 
              employing both traditional techniques and modern conservation standards 
              to ensure the longevity and integrity of every piece.
            </p>
          </div>

          <div class="pt-8 border-t border-neutral-100">
            <h2 class="text-xl font-medium mb-6">{copy.contactTitle}</h2>
            <div class="flex flex-wrap gap-x-8 gap-y-4">
              {copy.social.map(item => (
                <a 
                  href={item.href} 
                  class="text-neutral-500 hover:text-brand-500 transition-colors text-sm underline underline-offset-4"
                  target={item.href.startsWith('http') ? "_blank" : undefined}
                  rel={item.href.startsWith('http') ? "noopener noreferrer" : undefined}
                >
                  {item.label}
                </a>
              ))}
            </div>
          </div>
        </div>

        <div class="relative">
          <div class="aspect-[4/5] bg-neutral-100 rounded-lg overflow-hidden">
            <!-- Placeholder for about image -->
            <div class="absolute inset-0 flex items-center justify-center text-neutral-300 italic p-12 text-center">
              Professional biography image placeholder
            </div>
          </div>
          <div class="absolute -bottom-6 -left-6 w-32 h-32 bg-brand-500/10 rounded-full -z-10 blur-2xl"></div>
        </div>
      </div>
    </section>
  </main>
</BaseLayout>
