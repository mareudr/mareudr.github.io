---
import BaseLayout from '@layouts/BaseLayout.astro';
import { siteCopy } from '../../data/site';
import { Image } from 'astro:assets';
import contactBg from '../../assets/images/hero/hero-full2.jpg';

const copy = siteCopy.es;
const lang = 'es';
---

<BaseLayout lang={lang} title={`${copy.nav[4].label}`} description={copy.pageDescriptions.contact}>
  <main class="section-block min-h-[70vh] flex items-center">
    <section class="page-container w-full">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">
        <div class="space-y-8">
          <div>
            <p class="eyebrow mb-4">{copy.contactEyebrow}</p>
            <h1 class="section-title text-4xl md:text-5xl lg:text-6xl leading-tight">
              {copy.contactTitle}
            </h1>
          </div>
          
          <div class="text-lg text-neutral-600 font-light leading-relaxed max-w-lg">
            <p>{copy.contactBody}</p>
          </div>
        </div>

        <div class="relative overflow-hidden p-10 md:p-16 rounded-2xl shadow-sm border border-neutral-100 flex flex-col justify-center min-h-[450px]">
          <!-- Artistic Background -->
          <div class="absolute inset-0 z-0">
            <Image 
              src={contactBg} 
              alt="" 
              class="w-full h-full object-cover"
            />
            <div class="absolute inset-0 bg-white/70 backdrop-blur-[1px]"></div>
          </div>

          <div class="relative z-10 space-y-10">
            {copy.social.map(item => (
              <div class="group">
                <p class="text-[10px] uppercase tracking-widest text-neutral-400 mb-3">{item.label}</p>
                <a 
                  href={item.href} 
                  class="text-2xl md:text-3xl text-neutral-900 hover:text-brand-500 transition-colors font-light block break-all"
                  target={item.href.startsWith('http') ? "_blank" : undefined}
                  rel={item.href.startsWith('http') ? "noopener noreferrer" : undefined}
                >
                  {item.href.replace('mailto:', '').replace('https://', '')}
                </a>
              </div>
            ))}
          </div>
        </div>
      </div>
    </section>
  </main>
</BaseLayout>
